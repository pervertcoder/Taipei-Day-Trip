create database tourist_attraction;

create table attraction_info(
    id int auto_increment primary key,
    rate_data int null,
    direction_data text null,
    name_data varchar(100) null,
    date_data date null,
    longitude_data double null,
    REF_WP_data int null,
    avBegin_data date null,
    langinfo_data int null,
    MRT_data varchar(50) null,
    SERIAL_NO_data varchar(50) null,
    RowNumber_data int null,
    cate_data varchar(50) null,
    MEMO_TIME_data text null,
    POI_data varchar(20) null,
    file_data text null,
    idpt_data varchar(20) null,
    latitude_data double null,
    description_data text null,
    _id_data int null,
    avEnd_data date null,
    address_data varchar(100) null
);


insert into attraction_info(
    id,
    rate_data,
    direction_data,
    name_data,
    date_data,
    longitude_data,
    REF_WP_data,
    avBegin_data,
    langinfo_data,
    MRT_data,
    SERIAL_NO_data,
    RowNumber_data,
    cate_data,
    MEMO_TIME_data,
    POI_data,
    file_data,
    idpt_data,
    latitude_data,
    description_data,
    _id_data,
    avEnd_data,
    address_data
)values
    (),


create database web_attraction_mem;

create table web_attraction_memberinfo(
    id int auto_increment primary key,
    name varchar(100) not null,
    email varchar(100) not null,
    password varchar(100) not null
);

create table booking_data(
    id int primary key auto_increment,
    user_id int not null,
    attraction_id int not null,
    date varchar(50) not null,
    time varchar(50) not null,
    price int not null,
    foreign key (user_id) references web_attraction_memberinfo(id),
    foreign key (attraction_id) references attraction_info(id)
)

select
booking_data.id,
booking_data.attraction_id,
booking_data.user_id,
booking_data.date,
booking_data.time,
booking_data.price,
attraction_info.name_data,
attraction_info.address_data,
attraction_info.file_data
from booking_data
join attraction_info
on booking_data.attraction_id = attraction_info.id

create table order_data(
    id int primary key auto_increment,
    order_num varchar(20) not null,
    user_id int not null,
    user_name varchar(100) not null,
    user_phone varchar(20) not null,
    user_email varchar(100) not null,
    attraction_id int not null,
    attraction_name varchar(100) not null,
    attraction_address varchar(100) not null,
    image text not null,
    date varchar(50) not null,
    time varchar(50) not null,
    price int not null,    
    status ENUM('unpaid', 'paid') not null,
    foreign key (user_id) references web_attraction_memberinfo(id),
    foreign key (attraction_id) references attraction_info(id)
)

create table payment_data(
    id int primary key auto_increment,
    booking_id int not null,
    amount int not null,
    pay_time datetime default current_timestamp,
    foreign key (booking_id) references order_data(id)
)

delete from order_data where id = 1;
alter table order_data auto_increment = 1;